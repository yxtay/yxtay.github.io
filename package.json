{
  "name": "yxtay.github.io",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env SOCKET=true node ./scripts/next-remote-watch.js ./data",
    "dev": "next dev",
    "build": "next build --webpack",
    "export": "rm -rf out && mkdir out && cp -r .next/server/pages/* out/ && (find out -name \"*[*\" -exec rm -rf {} +) && cp -r public/* out/ && npx next-export-optimize-images && node ./scripts/generate-sitemap",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir components --dir lib --dir layouts --dir scripts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@fontsource/inter": "4.5.2",
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.28.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "mdx-bundler": "^10.1.1",
    "next": "^16.2.6",
    "next-export-optimize-images": "^4.7.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.38",
    "preact": "^10.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "^7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark-footnotes": "^4.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "cross-env": "^7.0.3",
    "dedent": "^1.5.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "file-loader": "^6.0.0",
    "globby": "^11.0.3",
    "husky": "^9.0.11",
    "inquirer": "^9.2.22",
    "lint-staged": "^15.2.7",
    "next-remote-watch": "^1.0.0",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "socket.io": "^4.4.0",
    "socket.io-client": "^4.4.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}