    "@svgr/webpack": "^8.1.0",
    "cross-env": "^10.1.0",
    "dedent": "^1.7.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globby": "^11.1.0",
    "husky": "^9.1.7",
    "inquirer": "^9.3.8",
    "lint-staged": "^15.5.2",
    "next-remote-watch": "^1.0.0",
    "prettier": "^3.8.3",
